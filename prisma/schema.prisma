generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int     @id @default(autoincrement())
  username  String  @unique
  password  String
  role      String  @default("USER")
  email     String? @unique
  name      String?
  reservations Reservation[]
  drivers      Driver[]
  taxis        Taxi[]
  yachts       Yacht[]
  crew         Crew[]
  places       Place[]
  airports     Airport[]
  hotels       Hotel[]
  beaches      Beach[]
  attractions  Attraction[]
  restaurants  Restaurant[]
  packages     Package[]
  packageReservations PackageReservation[]
}

model Driver {
  id           Int      @id @default(autoincrement())
  name         String
  license      String
  phone        String
  expiration   String?
  rating       Float    @default(5.0)
  photo        String?
  availability Boolean  @default(true)
  taxis        Taxi[]
  packages     Package[]
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id])
}

model Taxi {
  id           Int      @id @default(autoincrement())
  plate        String   @unique
  brand        String
  model        String
  year         Int
  color        String
  type         String
  passengers   Int
  luggage      Int
  amenities    String[] @default([])
  status       String   @default("Disponible")
  driverId     Int
  driver       Driver   @relation(fields: [driverId], references: [id])
  reservations ReservationService[]
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id])
}

model Yacht {
  id           Int      @id @default(autoincrement())
  name         String
  brand        String
  model        String
  year         Int
  length       String
  capacity     Int
  price_day    Float
  status       String   @default("Disponible")
  location     String
  coordinates  String
  availability Boolean  @default(true)
  crew         Crew[]
  reservations ReservationService[]
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id])
}

model Crew {
  id           Int      @id @default(autoincrement())
  name         String
  role         String
  experience   String
  phone        String?
  photo        String?
  yachtId      Int
  yacht        Yacht    @relation(fields: [yachtId], references: [id])
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id])
}

model Place {
  id           Int      @id @default(autoincrement())
  name         String
  category     String
  reservations ReservationService[]
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id])
}

model Airport {
  id           Int      @id @default(autoincrement())
  name         String
  location     String
  iata         String   @unique
  city         String
  state        String
  status       String   @default("Operativo")
  coordinates  String
  reservations ReservationService[]
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id])
}

model Hotel {
  id           Int      @id @default(autoincrement())
  name         String
  location     String
  stars        Int      @default(5)
  city         String
  state        String
  status       String   @default("Disponible")
  coordinates  String
  reservations ReservationService[]
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id])
}

model Beach {
  id           Int      @id @default(autoincrement())
  name         String
  type         String
  city         String
  state        String
  status       String   @default("Abierta")
  coordinates  String
  popularity   String   @default("Media")
  reservations ReservationService[]
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id])
}

model Attraction {
  id              Int      @id @default(autoincrement())
  name            String
  category        String
  city            String
  state           String
  status          String   @default("Abierto")
  coordinates     String
  recommendedTime String   @default("2 Horas")
  reservations    ReservationService[]
  userId          Int?
  user            User?    @relation(fields: [userId], references: [id])
}

model Restaurant {
  id           Int      @id @default(autoincrement())
  name         String
  cuisine      String
  city         String
  state        String
  status       String   @default("Abierto")
  coordinates  String
  priceRange   String   @default("$$")
  reservations ReservationService[]
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id])
}

model Reservation {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime @default(now())
  totalAmount Float
  status      String   @default("PENDING")
  services    ReservationService[]
}

model ReservationService {
  id            Int      @id @default(autoincrement())
  reservationId Int
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  
  serviceType   String
  
  taxiId        Int?
  taxi          Taxi?    @relation(fields: [taxiId], references: [id])
  
  yachtId       Int?
  yacht         Yacht?   @relation(fields: [yachtId], references: [id])
  
  placeId       Int?
  place         Place?   @relation(fields: [placeId], references: [id])
  
  restaurantId  Int?
  restaurant    Restaurant? @relation(fields: [restaurantId], references: [id])

  airportId     Int?
  airport       Airport?    @relation(fields: [airportId], references: [id])

  hotelId       Int?
  hotel         Hotel?      @relation(fields: [hotelId], references: [id])

  beachId       Int?
  beach         Beach?      @relation(fields: [beachId], references: [id])

  attractionId  Int?
  attraction    Attraction?    @relation(fields: [attractionId], references: [id])
  
  quantity      Int      @default(1)
  price         Float
}

model Package {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  status      String   @default("Borrador")
  price       Float
  sales       Int      @default(0)
  date        String
  image       String?
  start_time  String?  @default("08:00")
  items       Json?    // Stores the itinerary items
  driverId    Int?     // Stores the assigned driver
  driver      Driver?  @relation(fields: [driverId], references: [id])
  clientId    String?  // UUID to track custom packages in session
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])
  packageReservations PackageReservation[]
}

model PackageReservation {
  id              Int      @id @default(autoincrement())
  packageId       Int
  package         Package  @relation(fields: [packageId], references: [id])
  userId          Int?     // Owner of the package
  user            User?    @relation(fields: [userId], references: [id])
  
  customerName    String
  customerEmail   String
  customerPhone   String
  customerCountry String?
  
  date            String   // Date of the tour
  time            String   // Time of the tour
  passengers      Int
  totalPrice      Float
  status          String   @default("Confirmado") // Since it's post-payment
  notes           String?  @db.Text
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
